# Jarvis configuration template — copy to ".env" and fill in your values.
# .env is git-ignored so your real secrets never get committed.

# Required for the offline wake word ("Jarvis"). Get a free key at:
#   https://console.picovoice.ai/
PICOVOICE_ACCESS_KEY=your-picovoice-access-key-here

# Optional overrides:
# PORCUPINE_SENSITIVITY=1.0
# MIC_INDEX=2
# OLLAMA_URL=http://localhost:11434
# LLM_MODEL=llama3.2:3b
# VISION_MODEL=llava:13b
# JARVIS_CREATOR=YourName          # overrides identity.creator in jarvis.yaml
